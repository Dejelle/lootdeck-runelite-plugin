# Normalize text to LF in the repo; keep the wrapper script LF so the Plugin Hub's
# Linux CI can execute ./gradlew (a CRLF shebang would break it).
* text=auto eol=lf
gradlew text eol=lf
*.sh text eol=lf
gradlew.bat text eol=crlf
*.bat text eol=crlf

# Binary assets — never touch line endings.
*.jar binary
*.png binary
